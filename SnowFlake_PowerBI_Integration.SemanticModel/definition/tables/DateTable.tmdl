	partition DateTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDARAUTO(),
				    "Year",       YEAR ( [Date] ),
				    "Month Num",  MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMM" ),
				    "Quarter",    "Q" & QUARTER ( [Date] ),
				    "YearMonth",  FORMAT ( [Date], "YYYY-MM" )
				)

	annotation PBI_Id = af5318f9e797496f80f201cb894a3a64

